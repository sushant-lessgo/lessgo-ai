</style><nav class="hearth-nav"><div class="hearth-nav__left"><div class="hearth-nav__brand"><div class="hearth-nav__brand-mark">a</div><span>atelier hearth</span></div><div class="hearth-nav__links"><a href="#work" class="hearth-nav__link is-active">Work</a><a href="#services" class="hearth-nav__link">Services</a><a href="#about" class="hearth-nav__link">About</a><a href="#contact" class="hearth-nav__link">Contact</a></div></div><div class="hearth-nav__right"><a class="hearth-btn hearth-btn--primary hearth-btn--sm" href="#cta" data-lessgo-cta="" data-lessgo-cta-role="primary">Book a call</a></div></nav></div><div id="hero" data-surface="cream" style="scroll-margin-top:80px"><style>
.hearth-hero {
