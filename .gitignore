# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# sentry
.env.sentry-build-plugin

# typescript
*.tsbuildinfo
next-env.d.ts

_Archived
# clerk configuration (can include secrets)
/.clerk/

# e2e Clerk session state + Playwright artifacts
e2e/.clerk/
/test-results/
/playwright-report/

# test background
src/app/TestBackground/

# user uploaded images
public/uploads/**
!public/uploads/.gitkeep


tmpclaude-*

# service pilot dogfood outputs
/dogfoodOutput/

# Prod data backups (never commit)
backups/

# Designer handoff package (local reference only; not shipped)
Lessgo.zip
design_handoff_naayom/

# Design source stays local (brand assets, future designer drops) — EXCEPT the
# UI-redesign handoff, which Lane-1 + work-onboarding specs cite BY PATH, so it
# must exist in every worktree. Parent dirs are re-included explicitly: git never
# descends into an excluded directory, so `!` alone on a nested path won't work.
docs/Design/*
!docs/Design/Lessgo AI UI redesign/
docs/Design/Lessgo AI UI redesign/*
!docs/Design/Lessgo AI UI redesign/design_handoff_lessgo_app/

# Template design mockups (local reference only)
template-design/
.claude/settings.local.json

docs/research/coverage-100/raw/

# shared session mailbox (see CLAUDE.md)
.claude/mailbox/
